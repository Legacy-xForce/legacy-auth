DATABASE_URL=postgres://postgres:postgres@localhost:5432/legacy_auth
JWT_SECRET=super-secret-jwt-key
# EC P-256 private key in PEM format used to sign access tokens (ES256).
# Generate with: openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt
# If unset, an ephemeral key is generated at startup (tokens are invalidated on restart).
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgGgQyaehoVvg00Qwk\nBv6y4uoEEROhwrsSq8jpvi5BIKChRANCAATPbSqU+iV1/JhngHtFLuYHVNbjrixc\ndspmM504fBUFH28hJ+xPCcKH7dGKO2mcjzY/n8BqAxMvG+bEXQgyfGXd\n-----END PRIVATE KEY-----
# Optional key ID override. Defaults to the RFC 7638 SHA-256 thumbprint of the public key.
JWT_KEY_ID=
PORT=4000
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
CACHE_TTL_MS=300000
BCRYPT_SALT_ROUNDS=12
